{
  "name": "do-test",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "deploy": "bun run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:generate": "bun --env-file=.env x drizzle-kit generate --config worker/drizzle.config.ts",
    "db:migrate": "bun --env-file=.env x drizzle-kit migrate --config worker/drizzle.config.ts",
    "db:push": "bun --env-file=.env x drizzle-kit push --config worker/drizzle.config.ts",
    "db:studio": "bun --env-file=.env x drizzle-kit studio --config worker/drizzle.config.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.5",
    "hono": "^4.9.6",
    "postgres": "^3.4.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.13.0",
    "@cloudflare/workers-types": "^5.20260713.1",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "drizzle-kit": "^0.31.4",
    "oxlint": "^1.73.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "wrangler": "^4.28.0"
  }
}
